# Next-web 生产环境配置
# ⚠️ 此文件用于生产构建（npm run build:prod），Cloudflare 部署时使用 CF 环境变量

# 后端API地址（生产环境）

NEXT_PUBLIC_API_URL=http://local.zeusai.top:8890

# 站点ID
NEXT_PUBLIC_SITE_ID=1

# API访问密钥（可选）
NEXT_PUBLIC_API_KEY=

# 重新验证密钥
REVALIDATE_SECRET=your-random-secret-key-here

# games sitemap 分页结果缓存 TTL（毫秒）
# 0 表示禁用缓存
SITEMAP_GAME_PAGE_CACHE_TTL_MS=60000
